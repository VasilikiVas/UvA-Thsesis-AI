python reader.py --export_color_images --filename ./scans/scene0002_00/scene0002_00.sens --output_path ./scans/scene0002_00
python reader.py --export_color_images --filename ./scans/scene0002_01/scene0002_01.sens --output_path ./scans/scene0002_01
