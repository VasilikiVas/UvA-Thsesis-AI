python reader.py --export_color_images --filename ./scans/scene0006_01/scene0006_01.sens --output_path ./scans/scene0006_01
python reader.py --export_color_images --filename ./scans/scene0006_02/scene0006_02.sens --output_path ./scans/scene0006_02
