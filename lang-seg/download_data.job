#!/bin/bash

#SBATCH --partition=normal
#SBATCH --gres=gpu:0
#SBATCH --job-name=DownloadData
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --time=06:00:00
#SBATCH --mem=64000M
#SBATCH --output=slurm_output_%A.out

cd $HOME/lang-seg/
conda activate py27
python reader.py --export_color_images --filename ./scans/scene0000_00/scene0000_00.sens --output_path ./scans/scene0000_00
